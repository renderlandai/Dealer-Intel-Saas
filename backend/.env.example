# ── Backend Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# AI — Claude image analysis (required)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Bright Data Web Unlocker (required for WAF-protected dealer sites)
# Token from https://brightdata.com/cp/api_tokens; zone configured under
# Web Unlocker in the BD dashboard. Used by services/unlocker_service.py
# as the top rung of every ladder in services/render_strategies.py.
# Leave blank for local dev — the smoke test will disable the rung at
# boot and the API will still serve.
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_UNLOCKER_ZONE=dealer_intel_unlocker

# Optional pricing override (per successful unlock, USD). Defaults to
# 0.0015 (PAYG list). Set this if you move to a bundled volume tier.
# BRIGHTDATA_UNLOCKER_COST_PER_REQUEST_USD=0.0010

# Scan source APIs (enable as needed)
SERPAPI_API_KEY=                # Google Ads Transparency Center
APIFY_API_KEY=                 # Meta Ad Library + Instagram

# Email notifications
RESEND_API_KEY=

# Redis — used for APScheduler leader election
REDIS_URL=redis://localhost:6379/0

# Error tracking (leave empty to disable)
SENTRY_DSN=

# Stripe billing (optional for local dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_EXTRA_DEALER_STARTER=price_...
STRIPE_PRICE_EXTRA_DEALER_PROFESSIONAL=price_...
STRIPE_PRICE_EXTRA_DEALER_BUSINESS=price_...

# Slack integration (OAuth)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Salesforce integration (OAuth)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Dropbox integration (OAuth)
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# Jira / Atlassian integration (OAuth 2.0 3LO)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# HubSpot integration (OAuth 2.0)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# App settings
DEBUG=true
CORS_ORIGINS=http://localhost:3000
ENABLE_DANGEROUS_ENDPOINTS=false
FRONTEND_URL=http://localhost:3000

# ── Playwright (website scans) ───────────────────────────────────
# After 'pip install -r requirements.txt' run:
#     ./scripts/install_playwright.sh
# On Apple Silicon inside Cursor's sandbox, Playwright's CPU detection
# fails and it pulls mac-x64 binaries while the runtime expects mac-arm64.
# The script exports PLAYWRIGHT_HOST_PLATFORM_OVERRIDE to force the right build.
# You can also set this manually in your shell if invoking 'playwright install' directly:
# PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64
